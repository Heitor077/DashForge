{
  "name": "dashforge",
  "version": "1.0.0",
  "description": "Dashboard interactivo desktop con Angular + Electron",
  "author": "Heitor Raga Lara",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:web": "ng serve",
    "start:desktop": "npm run electron:dev",
    "electron:dev": "concurrently -k \"npm run start:web\" \"wait-on tcp:4200 && cross-env ELECTRON_START_URL=http://localhost:4200 electron .\"",
    "build": "ng build --configuration production",
    "build:web": "ng build --configuration production",
    "build:desktop": "npm run build:desktop:installer",
    "build:desktop:dir": "npm run build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --dir",
    "build:desktop:installer": "npm run build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "electron:build": "npm run build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "npm run build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "build": {
  "appId": "com.heitor.dashforge",
  "productName": "DashForge",
  "asar": true,
  "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
  "directories": {
    "buildResources": "electron/assets",
    "output": "release"
  },
  "files": [
    "dist/dash-boar-interactivo/browser/**/*",
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "electron/assets/icon.ico",
      "to": "assets/icon.ico"
    }
  ],
  "win": {
    "icon": "electron/assets/icon.ico",
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },

    "nsis": {
      "shortcutName": "Dashboard Interactivo",
      "createDesktopShortcut": "always",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.10",
    "@angular/cli": "^19.2.10",
    "@angular/compiler-cli": "^19.2.0",
    "@types/jasmine": "~5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.7.2",
    "wait-on": "^9.0.3"
  }
}
